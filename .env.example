# Banco de dados PostgreSQL (privacy by design — não guarda PII do denunciante).
# Preencha após provisionar a infra (tarefa "Modelagem de dados e setup da infra").
DATABASE_URL="postgresql://usuario:senha@localhost:5432/canal_denuncias?schema=public"

# Auth.js — segredo de sessão do painel interno. Gere com: openssl rand -base64 32
AUTH_SECRET=""

# Web Push (VAPID) — notificação do painel. Gere com: pnpm exec web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@exemplo.com"
# A pública precisa ser exposta ao cliente (mesmo valor de VAPID_PUBLIC_KEY):
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
